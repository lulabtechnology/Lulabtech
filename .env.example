RESEND_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_TO_EMAIL=ventas@lulabtech.com
NEXT_PUBLIC_SITE_URL=https://www.lulabtech.com
# WhatsApp publico centralizado en lib/constants.ts: 50767069044

# FASE 4 — Medición y verificación
# GA4: crear propiedad en Google Analytics y pegar el Measurement ID con formato G-XXXXXXXXXX.
NEXT_PUBLIC_GA_ID=

# GTM: crear contenedor Web en Google Tag Manager y pegar el Container ID con formato GTM-XXXXXXX.
NEXT_PUBLIC_GTM_ID=

# Google Search Console: usar verificación por DNS preferiblemente.
# Si eliges URL prefix + etiqueta HTML, pega solo el contenido del meta tag google-site-verification.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Meta Pixel: ya existe un Pixel configurado en el proyecto. Cambiar solo si Meta entrega otro ID.
NEXT_PUBLIC_META_PIXEL_ID=1475809483955480

# Google Reviews — sección de reseñas verificadas
# 1) GOOGLE_PLACES_API_KEY queda solo en servidor/Vercel, nunca en el navegador.
# 2) GOOGLE_PLACE_ID es el Place ID del perfil de Google Business de LulabTech.
# 3) NEXT_PUBLIC_GOOGLE_REVIEWS_URL es el enlace público para ver reseñas en Google Maps.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
NEXT_PUBLIC_GOOGLE_REVIEWS_URL=
